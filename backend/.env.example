# Copy to .env and adjust. Every variable has a working default — the app
# runs with no .env at all.

# sqlite locally; Postgres in production, e.g. postgresql://user:pass@host/db (Neon works)
DATABASE_URL=sqlite:///./battle.db

# Comma-separated allowed frontend origins
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

LOG_LEVEL=INFO

# AI battle commentary provider: local | ollama | openrouter
# "local" is a deterministic template engine — zero credentials, works offline.
AI_PROVIDER=local

# Only needed when AI_PROVIDER=ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

# Only needed when AI_PROVIDER=openrouter (free models available)
OPENROUTER_API_KEY=
OPENROUTER_MODEL=meta-llama/llama-3.3-70b-instruct:free
